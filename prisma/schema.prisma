generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institute {
  id        String    @id @default(uuid())
  name      String
  logo      String?
  status    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  courses   Course[]
  payments  Payment[]
  users     User[]

  @@index([deletedAt])
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  role          Role
  instituteId   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  certificates  Certificate[]
  coursesTaught Course[]      @relation("FacultyCourses")
  enrollments   Enrollment[]
  institute     Institute?    @relation(fields: [instituteId], references: [id])
  progresses    Progress[]
  submissions   Submission[]

  @@index([role])
  @@index([deletedAt])
}

model Course {
  id           String        @id @default(uuid())
  title        String
  description  String?
  courseCode   String        @unique
  instituteId  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  facultyId    String?
  assignments  Assignment[]
  batches      Batch[]
  certificates Certificate[]
  faculty      User?         @relation("FacultyCourses", fields: [facultyId], references: [id])
  institute    Institute     @relation(fields: [instituteId], references: [id])
  tests        Test[]
  videos       Video[]
  materials    Material[]

  @@index([instituteId])
  @@index([facultyId])
  @@index([deletedAt])
}

model Batch {
  id          String       @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  courseId    String
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?
  course      Course       @relation(fields: [courseId], references: [id])
  enrollments Enrollment[]

  @@index([courseId])
  @@index([deletedAt])
}

model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  batchId    String
  enrolledAt DateTime @default(now())
  batch      Batch    @relation(fields: [batchId], references: [id])
  student    User     @relation(fields: [studentId], references: [id])

  @@unique([studentId, batchId])
  @@index([studentId])
  @@index([batchId])
}

model Video {
  id          String    @id @default(uuid())
  title       String
  description String?
  videoUrl    String
  storagePath String?
  fileName    String?
  fileSize    Int?
  mimeType    String?
  duration    Int?
  sortOrder   Int       @default(0)
  published   Boolean   @default(true)
  courseId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  course      Course    @relation(fields: [courseId], references: [id])
  progresses  Progress[]

  @@index([courseId])
  @@index([deletedAt])
}

model Material {
  id           String       @id @default(uuid())
  title        String
  description  String?
  fileUrl      String
  materialType MaterialType @default(PDF)
  sortOrder    Int          @default(0)
  courseId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  course       Course       @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([deletedAt])
}

model Assignment {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  courseId    String
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?
  course      Course       @relation(fields: [courseId], references: [id])
  submissions Submission[]

  @@index([courseId])
  @@index([deletedAt])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  fileName     String?
  mimeType     String?
  fileSize     Int?
  submittedAt  DateTime   @default(now())
  grade        Int?
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      User       @relation(fields: [studentId], references: [id])

  @@index([assignmentId])
  @@index([studentId])
}

model Test {
  id         String    @id @default(uuid())
  title      String
  totalMarks Int
  duration   Int
  courseId   String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  course     Course    @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([deletedAt])
}

model Certificate {
  id            String            @id @default(uuid())
  certificateNo String            @unique
  studentId     String
  courseId      String
  qrCodeUrl     String?
  status        CertificateStatus @default(ACTIVE)
  issueDate     DateTime
  createdAt     DateTime          @default(now())
  deletedAt     DateTime?
  course        Course            @relation(fields: [courseId], references: [id])
  student       User              @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([courseId])
  @@index([deletedAt])
}

model Payment {
  id          String    @id @default(uuid())
  amount      Float
  instituteId String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  institute   Institute @relation(fields: [instituteId], references: [id])

  @@index([instituteId])
  @@index([deletedAt])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FACULTY
  STUDENT
}

enum CertificateStatus {
  ACTIVE
  REVOKED
}

enum MaterialType {
  PDF
  DOC
  DOCX
  PPT
  PPTX
  XLSX
  OTHER
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  completed Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}
