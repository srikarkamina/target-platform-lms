generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Institute {
  id        String    @id @default(uuid())
  name      String
  logo      String?
  status       InstituteStatus @default(ACTIVE)
  isDeleted    Boolean         @default(false)
  suspendedAt  DateTime?
  suspendedBy  String?
  lastActiveAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  courses   Course[]
  payments  Payment[]
  users                User[]
  quizzes              Quiz[]
  certificates         Certificate[]
  certificateTemplates CertificateTemplate[]
  notifications        Notification[]
  settings             InstituteSettings?
  auditLogs            AuditLog[]
  emailTemplates       EmailTemplate[]
  emailHistories       EmailHistory[]
  subscription         Subscription?
  usageSnapshots       UsageSnapshot[]
  announcements        Announcement[]
  discussions          Discussion[]
  discussionReplies    DiscussionReply[]
  discussionLikes      DiscussionLike[]
  doubts               Doubt[]
  doubtReplies         DoubtReply[]
  feedbacks            Feedback[]
  polls                Poll[]
  events               Event[]

  // Admin information fields
  adminName            String          @default("")
  adminEmail           String          @default("")
  adminPhone           String?
  adminId              String?         @unique
  admin                User?           @relation("InstituteAdmin", fields: [adminId], references: [id])

  @@index([deletedAt])
}

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  passwordHash   String?
  passwordSet    Boolean       @default(false)
  role           Role
  status         UserStatus    @default(ACTIVE)
  instituteId    String?
  phone          String?
  department     String?
  createdBy      String?
  lastLogin      DateTime?
  provider       String?       @default("credentials")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  certificates   Certificate[]
  coursesTaught  Course[]      @relation("FacultyCourses")
  enrollments    Enrollment[]
  institute      Institute?    @relation(fields: [instituteId], references: [id])
  administeredInstitute Institute?    @relation("InstituteAdmin")
  progresses     Progress[]
  submissions    Submission[]
  quizzesCreated Quiz[]        @relation("CreatedQuizzes")
  quizAttempts   QuizAttempt[] @relation("StudentQuizAttempts")
  notifications  Notification[]
  auditLogs      AuditLog[]
  emailHistories       EmailHistory[]
  announcementsCreated Announcement[]
  discussionsCreated   Discussion[]
  discussionReplies    DiscussionReply[]
  discussionLikes      DiscussionLike[]
  assignedDoubts       Doubt[]               @relation("AssignedDoubts")
  createdDoubts        Doubt[]               @relation("CreatedDoubts")
  doubtReplies         DoubtReply[]
  facultyFeedbacks     Feedback[]            @relation("FacultyFeedback")
  userFeedbacks        Feedback[]            @relation("UserFeedback")
  pollsCreated         Poll[]
  pollVotes            PollVote[]
  eventsCreated        Event[]
  eventRegistrations   EventRegistration[]

  @@index([role])
  @@index([instituteId])
  @@index([deletedAt])
}

model Course {
  id           String        @id @default(uuid())
  title        String
  description  String?
  courseCode   String        @unique
  instituteId  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  facultyId    String?
  assignments  Assignment[]
  batches      Batch[]
  certificates Certificate[]
  faculty      User?         @relation("FacultyCourses", fields: [facultyId], references: [id])
  institute    Institute     @relation(fields: [instituteId], references: [id])
  tests        Test[]
  videos       Video[]
  materials    Material[]
  quizzes      Quiz[]
  announcements Announcement[]
  discussions   Discussion[]
  doubts        Doubt[]
  feedbacks     Feedback[]

  @@index([instituteId])
  @@index([facultyId])
  @@index([deletedAt])
}

model Batch {
  id          String       @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  courseId    String
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?
  course      Course       @relation(fields: [courseId], references: [id])
  enrollments   Enrollment[]
  announcements Announcement[]

  @@index([courseId])
  @@index([deletedAt])
}

model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  batchId    String
  enrolledAt DateTime @default(now())
  batch      Batch    @relation(fields: [batchId], references: [id])
  student    User     @relation(fields: [studentId], references: [id])

  @@unique([studentId, batchId])
  @@index([studentId])
  @@index([batchId])
}

model Video {
  id          String     @id @default(uuid())
  title       String
  description String?
  videoUrl    String
  storagePath String?
  fileName    String?
  fileSize    Int?
  mimeType    String?
  duration    Int?
  sortOrder   Int        @default(0)
  published   Boolean    @default(true)
  courseId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  course      Course     @relation(fields: [courseId], references: [id])
  progresses  Progress[]

  @@index([courseId])
  @@index([deletedAt])
}

model Material {
  id           String       @id @default(uuid())
  title        String
  description  String?
  fileUrl      String
  materialType MaterialType @default(PDF)
  sortOrder    Int          @default(0)
  courseId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  course       Course       @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([deletedAt])
}

model Assignment {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  courseId    String
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?
  course      Course       @relation(fields: [courseId], references: [id])
  submissions Submission[]

  @@index([courseId])
  @@index([deletedAt])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  fileName     String?
  mimeType     String?
  fileSize     Int?
  submittedAt  DateTime   @default(now())
  grade        Int?
  feedback     String?
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      User       @relation(fields: [studentId], references: [id])

  @@index([assignmentId])
  @@index([studentId])
}

model Test {
  id         String    @id @default(uuid())
  title      String
  totalMarks Int
  duration   Int
  courseId   String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  course     Course    @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([deletedAt])
}

model CertificateTemplate {
  id              String    @id @default(uuid())
  instituteId     String
  name            String
  title           String
  description     String?
  backgroundImage     String?
  backgroundImageSize Int?
  signatureImage      String?
  signatureImageSize  Int?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  institute    Institute     @relation(fields: [instituteId], references: [id])
  certificates Certificate[]
  defaultSettings InstituteSettings[] @relation("DefaultTemplate")

  @@index([instituteId])
  @@index([deletedAt])
}

model Certificate {
  id                String            @id @default(uuid())
  instituteId       String
  studentId         String
  courseId          String
  templateId        String
  certificateNumber String            @unique
  certificateCode   String            @unique
  verificationToken String            @unique
  issueDate         DateTime          @default(now())
  completionDate    DateTime?
  certificateUrl    String?
  fileSize          Int?
  status            CertificateStatus @default(ACTIVE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  revokedAt         DateTime?

  institute Institute           @relation(fields: [instituteId], references: [id])
  student   User                @relation(fields: [studentId], references: [id])
  course    Course              @relation(fields: [courseId], references: [id])
  template  CertificateTemplate @relation(fields: [templateId], references: [id])

  @@index([instituteId])
  @@index([studentId])
  @@index([courseId])
  @@index([templateId])
  @@index([deletedAt])
}

model Payment {
  id          String    @id @default(uuid())
  amount      Float
  instituteId String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  institute   Institute @relation(fields: [instituteId], references: [id])

  @@index([instituteId])
  @@index([deletedAt])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FACULTY
  STUDENT
}

enum CertificateStatus {
  ACTIVE
  REVOKED
}

enum InstituteStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

enum MaterialType {
  PDF
  DOC
  DOCX
  PPT
  PPTX
  XLSX
  OTHER
}

model Progress {
  id        String  @id @default(cuid())
  userId    String
  videoId   String
  completed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

model Quiz {
  id           String    @id @default(uuid())
  title        String
  description  String?
  courseId     String
  timeLimit    Int
  passingMarks Int
  totalMarks   Int
  isPublished  Boolean   @default(false)
  createdBy    String
  instituteId  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  creator   User          @relation("CreatedQuizzes", fields: [createdBy], references: [id])
  institute Institute     @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([createdBy])
  @@index([instituteId])
  @@index([deletedAt])
}

model Question {
  id             String       @id @default(uuid())
  quizId         String
  question       String
  options        Json
  correctAnswers Json
  questionType   QuestionType
  marks          Int
  order          Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  studentId   String
  score       Float
  percentage  Float
  passed      Boolean
  status      String    @default("IN_PROGRESS")
  startedAt   DateTime
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student User         @relation("StudentQuizAttempts", fields: [studentId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
  @@index([studentId])
}

model QuizAnswer {
  id              String  @id @default(uuid())
  attemptId       String
  questionId      String
  selectedAnswers Json
  isCorrect       Boolean

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
}

model Notification {
  id          String               @id @default(uuid())
  title       String
  message     String
  type        NotificationType
  priority    NotificationPriority @default(NORMAL)
  actionUrl   String?
  expiresAt   DateTime?
  isRead      Boolean              @default(false)
  metadata    Json                 @default("{}")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  instituteId String
  institute   Institute            @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([instituteId])
  @@index([isRead])
  @@index([deletedAt])
  @@index([expiresAt])
  @@index([priority])
}

enum NotificationType {
  ASSIGNMENT_CREATED
  ASSIGNMENT_DUE
  QUIZ_PUBLISHED
  QUIZ_DUE
  COURSE_ENROLLED
  COURSE_COMPLETED
  CERTIFICATE_ISSUED
  CERTIFICATE_REVOKED
  GENERAL
  ANNOUNCEMENT_PUBLISHED
  DISCUSSION_REPLY
  OFFICIAL_ANSWER
  DOUBT_ASSIGNED
  DOUBT_RESOLVED
  POLL_CREATED
  POLL_CLOSED
  EVENT_REMINDER
  EVENT_REGISTRATION
  FEEDBACK_RESPONSE
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model InstituteSettings {
  id                            String   @id @default(uuid())
  instituteId                   String   @unique
  
  // Institute Information
  name                          String?
  address                       String?
  city                          String?
  state                         String?
  country                       String?
  postalCode                    String?
  phone                         String?
  email                         String?
  website                       String?
  description                   String?

  // Branding
  logoUrl                       String?
  logoSize                      Int?
  bannerUrl                     String?
  bannerSize                    Int?
  faviconUrl                    String?
  faviconSize                   Int?
  primaryColor                  String   @default("#0f172a")
  secondaryColor                String   @default("#3b82f6")

  // Certificate Branding
  defaultSignatureImage         String?
  defaultSignatureImageSize     Int?
  defaultSealImage              String?
  defaultSealImageSize          Int?
  defaultCertificateTemplateId  String?

  // Localization
  timezone                      String   @default("UTC")
  dateFormat                    String   @default("YYYY-MM-DD")
  language                      String   @default("en")

  // SMTP Configuration
  smtpHost                      String?
  smtpPort                      Int?
  smtpUsername                  String?
  smtpPassword                  String?
  smtpEncryption                String?  @default("NONE") // NONE, SSL, TLS
  smtpSenderName                String?
  smtpSenderEmail               String?
  smtpReplyTo                   String?
  emailNotificationsEnabled     Boolean  @default(false)

  // Metadata
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  institute                     Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  defaultCertificateTemplate    CertificateTemplate? @relation("DefaultTemplate", fields: [defaultCertificateTemplateId], references: [id], onDelete: SetNull)

  @@index([instituteId])
}

model AuditLog {
  id            String   @id @default(uuid())
  instituteId   String
  userId        String?
  action        String
  module        String
  entityType    String?
  entityId      String?
  description   String?
  oldValues     Json?
  newValues     Json?
  ipAddress     String?
  userAgent     String?
  requestMethod String?
  requestPath   String?
  status        String   @default("SUCCESS")
  createdAt     DateTime @default(now())

  institute     Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([instituteId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([module])
}

enum EmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
  RETRYING
  CANCELLED
}

enum EmailType {
  WELCOME
  COURSE_ENROLLMENT
  ASSIGNMENT_CREATED
  ASSIGNMENT_REMINDER
  QUIZ_PUBLISHED
  QUIZ_REMINDER
  CERTIFICATE_ISSUED
  PASSWORD_RESET
  GENERAL
}

model EmailTemplate {
  id          String    @id @default(uuid())
  instituteId String
  type        EmailType
  subject     String
  body        String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([instituteId, type])
  @@index([instituteId])
}

model EmailHistory {
  id             String      @id @default(uuid())
  instituteId    String
  userId         String?
  recipientEmail String
  subject        String
  body           String      @db.Text
  type           EmailType
  status         EmailStatus @default(PENDING)
  retryCount     Int         @default(0)
  errorMessage   String?
  sentAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  institute      Institute   @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([instituteId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

model SubscriptionPlan {
  id             String         @id @default(uuid())
  name           String
  code           String         @unique
  price          Float
  maxStudents    Int?
  maxFaculty     Int?
  maxCourses     Int?
  maxAdmins      Int?
  storageLimitGB Float?
  trialDays      Int            @default(14)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
}

model Subscription {
  id           String             @id @default(uuid())
  instituteId  String             @unique
  planId       String
  status       SubscriptionStatus @default(TRIAL)
  startsAt     DateTime           @default(now())
  expiresAt    DateTime?
  trialEndsAt  DateTime?
  autoRenew    Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  institute    Institute          @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([instituteId])
  @@index([planId])
}

model UsageSnapshot {
  id            String    @id @default(uuid())
  instituteId   String
  students      Int
  faculty       Int
  admins        Int
  courses       Int
  storageUsedMB Float
  recordedAt    DateTime  @default(now())
  institute     Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
}

enum BackupType {
  MANUAL
  SCHEDULED
  SYSTEM
}

enum BackupStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model Backup {
  id          String       @id @default(uuid())
  type        BackupType   @default(MANUAL)
  status      BackupStatus @default(PENDING)
  fileName    String
  fileSize    Float        // Size in MB
  createdBy   String       // User ID or "SYSTEM"
  createdAt   DateTime     @default(now())
  completedAt DateTime?
  notes       String?
}

model Announcement {
  id             String                   @id @default(uuid())
  instituteId    String
  title          String
  description    String
  category       String                   // GENERAL, ACADEMIC, EXAM, HOLIDAY, PLACEMENT, EVENTS, EMERGENCY
  priority       String                   // LOW, MEDIUM, HIGH, CRITICAL
  publishDate    DateTime                 @default(now())
  expiryDate     DateTime?
  active         Boolean                  @default(true)
  pinned         Boolean                  @default(false)
  targetAudience String                   // EVERYONE, STUDENTS, FACULTY, COURSE, BATCH
  courseId       String?
  batchId        String?
  createdBy      String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?

  institute      Institute                @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  course         Course?                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batch          Batch?                   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  creator        User                     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  attachments    AnnouncementAttachment[]

  @@index([instituteId])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([publishDate])
}

model AnnouncementAttachment {
  id             String       @id @default(uuid())
  announcementId String
  fileUrl        String
  fileName       String
  mimeType       String?
  fileSize       Int?
  instituteId    String
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId])
  @@index([deletedAt])
}

model Discussion {
  id          String           @id @default(uuid())
  courseId    String
  title       String
  content     String
  pinned      Boolean          @default(false)
  locked      Boolean          @default(false)
  instituteId String
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  institute   Institute        @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  creator     User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  replies     DiscussionReply[]
  likes       DiscussionLike[]

  @@index([courseId])
  @@index([instituteId])
  @@index([createdBy])
  @@index([deletedAt])
}

model DiscussionReply {
  id               String            @id @default(uuid())
  discussionId     String
  parentId         String?
  content          String
  isOfficialAnswer Boolean           @default(false)
  instituteId      String
  createdBy        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  discussion       Discussion        @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parent           DiscussionReply?  @relation("NestedReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          DiscussionReply[] @relation("NestedReplies")
  institute        Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  creator          User              @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([parentId])
  @@index([instituteId])
  @@index([createdBy])
  @@index([deletedAt])
}

model DiscussionLike {
  id           String     @id @default(uuid())
  discussionId String
  userId       String
  instituteId  String
  createdBy    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  institute    Institute  @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
  @@index([discussionId])
  @@index([userId])
  @@index([instituteId])
  @@index([deletedAt])
}

model Doubt {
  id             String       @id @default(uuid())
  subject        String
  description    String
  courseId       String
  priority       String       // LOW, MEDIUM, HIGH, CRITICAL
  attachmentUrl  String?
  attachmentName String?
  anonymous      Boolean      @default(false)
  status         String       // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  assignedToId   String?
  instituteId    String
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignedTo     User?        @relation("AssignedDoubts", fields: [assignedToId], references: [id], onDelete: SetNull)
  creator        User         @relation("CreatedDoubts", fields: [createdBy], references: [id], onDelete: Cascade)
  institute      Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  replies        DoubtReply[]

  @@index([courseId])
  @@index([assignedToId])
  @@index([createdBy])
  @@index([instituteId])
  @@index([deletedAt])
}

model DoubtReply {
  id          String    @id @default(uuid())
  doubtId     String
  content     String
  instituteId String
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  doubt       Doubt     @relation(fields: [doubtId], references: [id], onDelete: Cascade)
  creator     User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([doubtId])
  @@index([instituteId])
  @@index([createdBy])
  @@index([deletedAt])
}

model Feedback {
  id                 String    @id @default(uuid())
  type               String    // COURSE, FACULTY, PLATFORM, BUG_REPORT, SUGGESTION
  courseId           String?
  facultyId          String?
  rating             Int?      // 1-5
  anonymous          Boolean   @default(false)
  comments           String
  semester           String?
  adminResponse      String?
  adminResponseAt    DateTime?
  adminResponseById  String?
  status             String    @default("PENDING")
  priority           String    @default("NORMAL")
  category           String    @default("PLATFORM")
  instituteId        String
  createdBy          String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  course      Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty     User?     @relation("FacultyFeedback", fields: [facultyId], references: [id], onDelete: Cascade)
  creator     User      @relation("UserFeedback", fields: [createdBy], references: [id], onDelete: Cascade)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([courseId])
  @@index([facultyId])
  @@index([instituteId])
  @@index([deletedAt])
}

model Poll {
  id             String       @id @default(uuid())
  question       String
  type           String       // SINGLE_CHOICE, MULTIPLE_CHOICE
  anonymous      Boolean      @default(false)
  publicResults  Boolean      @default(true)
  allowVoteUpdate Boolean     @default(false)
  expiryDate     DateTime
  instituteId    String
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  creator        User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  institute      Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  options        PollOption[]
  votes          PollVote[]

   @@index([instituteId])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([expiryDate])
}

model PollOption {
  id          String     @id @default(uuid())
  pollId      String
  text        String
  instituteId String
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  poll        Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes       PollVote[]

  @@index([pollId])
  @@index([deletedAt])
}

model PollVote {
  id          String     @id @default(uuid())
  pollId      String
  optionId    String
  userId      String
  instituteId String
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  poll        Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option      PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pollId])
  @@index([optionId])
  @@index([userId])
  @@index([deletedAt])
}

model Event {
  id                  String              @id @default(uuid())
  title               String
  description         String
  venue               String?
  onlineMeetingLink   String?
  speaker             String?
  banner              String?
  startDate           DateTime
  endDate             DateTime
  registrationRequired Boolean             @default(false)
  capacity            Int?
  reminderSent        Boolean             @default(false)
  instituteId         String
  createdBy           String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  creator             User                @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  institute           Institute           @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  registrations       EventRegistration[]

  @@index([instituteId])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([startDate])
  @@index([endDate])
}

model EventRegistration {
  id          String    @id @default(uuid())
  eventId     String
  studentId   String
  instituteId String
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
  @@index([eventId])
  @@index([studentId])
  @@index([deletedAt])
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  hash      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
  PENDING_INVITE
  DISABLED
}

enum AccessRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  ONBOARDING
  ACTIVE
  REJECTED
  CANCELLED
}

model AccessRequest {
  id            String              @id @default(uuid())
  requestNumber String              @unique
  instituteName String
  ownerName     String
  email         String              // Validation logic will block duplicates, not unique constraint, to allow resubmissions over time
  phone         String
  city          String
  state         String
  country       String
  website       String?
  requestedPlan String              // e.g. FREE, BASIC, PROFESSIONAL, ENTERPRISE
  message       String?             @db.Text
  status        AccessRequestStatus @default(SUBMITTED)
  reviewNotes   String?             @db.Text
  approvedBy    String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([email])
  @@index([status])
}


